# Normalise line endings in git to LF, check out as-is on Linux, CRLF on Windows
* text=auto eol=lf

# Force CRLF for Windows-specific files
*.ps1    text eol=crlf
*.bat    text eol=crlf
*.cmd    text eol=crlf

# Force LF for everything else
*.md     text eol=lf
*.txt    text eol=lf
*.json   text eol=lf
*.yaml   text eol=lf
*.yml    text eol=lf
*.sh     text eol=lf
*.py     text eol=lf
*.cs     text eol=lf
*.csv    text eol=lf
*.html   text eol=lf

# Binary files — no line ending conversion
*.png    binary
*.jpg    binary
*.jpeg   binary
*.gif    binary
*.ico    binary
*.pdf    binary
*.xlsx   binary
*.docx   binary
*.zip    binary
*.exe    binary
*.dll    binary
*.safetensors binary
