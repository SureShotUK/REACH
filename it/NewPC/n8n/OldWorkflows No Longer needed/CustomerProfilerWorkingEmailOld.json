    {
      "parameters": {
        "jsCode": "const item=$input.first().json;\nconst txt=(item.text||item.data||'').substring(0,1500);\nconst prompt='Extract from these UK company accounts: employee count, annual turnover in GBP, net assets in GBP, and financial year. Return JSON only with keys: turnover (number or null), employees (number or null), netAssets (number or null), year (string YYYY or null).\\n\\nACCOUNTS:\\n'+txt;\nconst body=JSON.stringify({model:'qwen3.6:27b',prompt:prompt,stream:false,format:'json'});\nreturn[{json:{ollamaBody:body}}];"
      },
