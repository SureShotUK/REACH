# Copy to n8n.env in this same folder and fill in the real key.
# This file is loaded via `env_file:` in docker-compose.yml — passed to the
# container byte-for-byte, no variable interpolation.
#
#   cp secrets/n8n.env.example secrets/n8n.env
#
# Must match the key n8n was first created with — changing it makes all
# stored n8n credentials unreadable. See n8n/N8N_Setup.md for the current key.

N8N_ENCRYPTION_KEY=your_n8n_encryption_key_here
