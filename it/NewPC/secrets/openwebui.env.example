# Copy to openwebui.env in this same folder and fill in the real password.
# This file is loaded via `env_file:` in docker-compose.yml — passed to the
# container byte-for-byte, no variable interpolation. Safe for values
# containing $, !, or other shell-special characters.
#
#   cp secrets/openwebui.env.example secrets/openwebui.env

PGVECTOR_DB_URL=postgresql://openwebui:your_postgresql_password_here@192.168.1.192:5432/openwebui_vectors
