@page
@model CompanyModel
@{
    ViewData["Title"] = Model.Profile?.CompanyName ?? "Company";
    var ch = $"https://find-and-update.company-information.service.gov.uk/company/{Model.Profile?.CompanyNumber}";
}

@* ── Back link ── *@
<a href="/" class="text-decoration-none text-muted mb-3 d-inline-block">&larr; New search</a>

@* ── Insolvency banner ── *@
@if (Model.IsInsolvent)
{
    <div class="insolvency-banner">
        <h5>&#9888; Insolvency Proceedings Recorded</h5>
        @foreach (var c in Model.Insolvency!.Cases)
        {
            <div class="mt-1">
                <strong>@c.Type.Replace("-", " ")</strong>
                @if (c.Dates.Any())
                {
                    <span class="ms-2 text-white-50">@c.Dates.First().Date</span>
                }
            </div>
        }
    </div>
}

@* ── Company profile ── *@
<div class="section-card">
    <div class="card-header p-3 d-flex justify-content-between align-items-center">
        <span>@Model.Profile!.CompanyName</span>
        <span class="badge badge-score rounded-pill fs-6">Score: @Model.MatchScore / 10</span>
    </div>
    <div class="card-body p-4">
        <div class="row g-3">
            <div class="col-md-6">
                <table class="table table-sm table-borderless mb-0">
                    <tr><th class="text-muted fw-normal" style="width:40%">Company number</th>
                        <td><a href="@ch" target="_blank">@Model.Profile.CompanyNumber</a></td></tr>
                    <tr><th class="text-muted fw-normal">Status</th>
                        <td>
                            <span class="badge @(Model.Profile.CompanyStatus == "active" ? "badge-active" : "bg-secondary") rounded-pill">
                                @Model.Profile.CompanyStatus
                            </span>
                        </td></tr>
                    <tr><th class="text-muted fw-normal">Type</th><td>@Model.Profile.CompanyType</td></tr>
                    <tr><th class="text-muted fw-normal">Incorporated</th><td>@Model.Profile.DateOfCreation</td></tr>
                    <tr><th class="text-muted fw-normal">Jurisdiction</th><td>@Model.Profile.Jurisdiction</td></tr>
                    @if (Model.Profile.HasCharges)
                    {
                        <tr><th class="text-muted fw-normal">Charges</th>
                            <td><span class="badge bg-warning text-dark rounded-pill">Charges registered</span></td></tr>
                    }
                </table>
            </div>
            <div class="col-md-6">
                <table class="table table-sm table-borderless mb-0">
                    <tr><th class="text-muted fw-normal" style="width:40%">Address</th>
                        <td>@Model.Profile.RegisteredOfficeAddress?.ToString()</td></tr>
                    <tr><th class="text-muted fw-normal">SIC codes</th>
                        <td>@string.Join(", ", Model.Profile.SicCodes)</td></tr>
                    <tr><th class="text-muted fw-normal">Product match</th>
                        <td><strong>@Model.ProductMatch</strong></td></tr>
                    @if (Model.Profile.Accounts?.LastAccounts is not null)
                    {
                        <tr><th class="text-muted fw-normal">Last accounts</th>
                            <td>@Model.Profile.Accounts.LastAccounts.MadeUpTo
                                <span class="text-muted">(@Model.Profile.Accounts.LastAccounts.Type)</span></td></tr>
                    }
                    @if (Model.Profile.Accounts?.NextAccounts is not null)
                    {
                        <tr><th class="text-muted fw-normal">Next accounts due</th>
                            <td>
                                @Model.Profile.Accounts.NextAccounts.DueOn
                                @if (Model.Profile.Accounts.NextAccounts.Overdue)
                                {
                                    <span class="badge bg-danger rounded-pill ms-1">Overdue</span>
                                }
                            </td></tr>
                    }
                    @if (Model.Profile.ConfirmationStatement is not null)
                    {
                        <tr><th class="text-muted fw-normal">Confirmation statement</th>
                            <td>
                                @Model.Profile.ConfirmationStatement.LastMadeUpTo
                                @if (Model.Profile.ConfirmationStatement.Overdue)
                                {
                                    <span class="badge bg-danger rounded-pill ms-1">Overdue</span>
                                }
                            </td></tr>
                    }
                </table>
            </div>
        </div>
    </div>
</div>

@* ── Active officers ── *@
<div class="section-card">
    <div class="card-header p-3">Active Officers (@Model.ActiveOfficers.Count)</div>
    <div class="card-body p-0">
        @if (Model.ActiveOfficers.Any())
        {
            <table class="table table-hover mb-0">
                <thead class="table-light">
                    <tr><th>Name</th><th>Role</th><th>Appointed</th><th>Nationality</th><th>Occupation</th></tr>
                </thead>
                <tbody>
                @foreach (var o in Model.ActiveOfficers.OrderBy(o => o.OfficerRole).ThenBy(o => o.Name))
                {
                    <tr>
                        <td class="fw-semibold">@System.Globalization.CultureInfo.CurrentCulture.TextInfo.ToTitleCase(o.Name.ToLower())</td>
                        <td><span class="badge badge-active rounded-pill">@o.OfficerRole</span></td>
                        <td>@o.AppointedOn</td>
                        <td>@o.Nationality</td>
                        <td>@o.Occupation</td>
                    </tr>
                }
                </tbody>
            </table>
        }
        else
        {
            <p class="text-muted p-3 mb-0">No active officers found.</p>
        }
    </div>
</div>

@* ── Recently resigned officers ── *@
@if (Model.ResignedOfficers.Any())
{
    <div class="section-card">
        <div class="card-header p-3">Recently Resigned Officers — last 18 months (@Model.ResignedOfficers.Count)</div>
        <div class="card-body p-0">
            <table class="table table-hover mb-0">
                <thead class="table-light">
                    <tr><th>Name</th><th>Role</th><th>Appointed</th><th>Resigned</th></tr>
                </thead>
                <tbody>
                @foreach (var o in Model.ResignedOfficers.OrderByDescending(o => o.ResignedOn))
                {
                    <tr>
                        <td>@System.Globalization.CultureInfo.CurrentCulture.TextInfo.ToTitleCase(o.Name.ToLower())</td>
                        <td><span class="badge badge-resigned rounded-pill">@o.OfficerRole</span></td>
                        <td>@o.AppointedOn</td>
                        <td>@o.ResignedOn</td>
                    </tr>
                }
                </tbody>
            </table>
        </div>
    </div>
}

@* ── Persons with significant control ── *@
<div class="section-card">
    <div class="card-header p-3">Persons with Significant Control (@Model.Persons.Count)</div>
    <div class="card-body p-0">
        @if (Model.Persons.Any())
        {
            <table class="table table-hover mb-0">
                <thead class="table-light">
                    <tr><th>Name</th><th>Nature of control</th><th>Notified on</th><th>Nationality</th></tr>
                </thead>
                <tbody>
                @foreach (var p in Model.Persons)
                {
                    <tr>
                        <td class="fw-semibold">@p.Name</td>
                        <td>@p.NaturesOfControlFormatted</td>
                        <td>@p.NotifiedOn</td>
                        <td>@p.Nationality</td>
                    </tr>
                }
                </tbody>
            </table>
        }
        else
        {
            <p class="text-muted p-3 mb-0">No persons with significant control recorded.</p>
        }
    </div>
</div>

@* ── Latest filed accounts ── *@
<div class="section-card">
    <div class="card-header p-3">Latest Filed Accounts</div>
    <div class="card-body p-3">
        @if (Model.LatestAccounts is not null)
        {
            <div class="d-flex justify-content-between align-items-center">
                <div>
                    <div class="fw-semibold">@Model.LatestAccounts.DescriptionFormatted</div>
                    <div class="text-muted">Filed: @Model.LatestAccounts.Date</div>
                </div>
                @if (Model.LatestAccounts.DocumentMetadataUrl is not null)
                {
                    <a href="?number=@Model.Profile.CompanyNumber&handler=Pdf&documentUrl=@Uri.EscapeDataString(Model.LatestAccounts.DocumentMetadataUrl)"
                       target="_blank"
                       class="btn btn-sm"
                       style="background-color:#002147;color:#fff;">
                        View PDF
                    </a>
                }
            </div>
        }
        else
        {
            <p class="text-muted mb-0">No accounts filing found.</p>
        }
    </div>
</div>
