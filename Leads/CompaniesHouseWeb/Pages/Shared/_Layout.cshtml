<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] — Portland Fuel</title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" />
    <style>
        body { background-color: #f8f9fa; }

        .navbar { background-color: #002147; }
        .navbar-brand, .navbar-brand:hover { color: #ffffff; font-weight: 600; letter-spacing: 0.5px; }

        .section-card { background: #fff; border-radius: 8px; box-shadow: 0 1px 4px rgba(0,0,0,.08); margin-bottom: 1.5rem; }
        .section-card .card-header { background-color: #002147; color: #fff; font-weight: 600; border-radius: 8px 8px 0 0; }

        .badge-active   { background-color: #198754; }
        .badge-resigned { background-color: #6c757d; }
        .badge-score    { background-color: #002147; }

        .insolvency-banner { background-color: #dc3545; color: #fff; border-radius: 8px; padding: 1rem 1.5rem; margin-bottom: 1.5rem; }
        .insolvency-banner h5 { margin: 0; font-weight: 700; }

        footer { background-color: #002147; color: #adb5bd; font-size: 0.85rem; padding: 1rem 0; margin-top: 3rem; }
    </style>
</head>
<body>

<nav class="navbar navbar-expand-lg mb-4">
    <div class="container">
        <a class="navbar-brand" href="/">Portland Fuel — Company Intelligence</a>
    </div>
</nav>

<div class="container">
    @RenderBody()
</div>

<footer>
    <div class="container text-center">Portland Fuel &copy; @DateTime.Now.Year</div>
</footer>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>
